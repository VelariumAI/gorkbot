{
    "name": "example_weather",
    "version": "1.0.0",
    "description": "Get weather information for a city using Python",
    "author": "gorkbot",
    "entry_point": "weather.py",
    "parameters": {
        "city": {
            "type": "string",
            "description": "City name to get weather for",
            "required": true,
            "default": "San Francisco"
        },
        "units": {
            "type": "string",
            "description": "Temperature units (celsius or fahrenheit)",
            "required": false,
            "default": "celsius"
        }
    },
    "requires": ["requests"],
    "category": "web"
}
