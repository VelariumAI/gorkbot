{
  "name": "rag_memory",
  "version": "1.0.0",
  "description": "Semantic RAG memory — ChromaDB vector store + MiniLM embeddings. Actions: store, search, stats, purge.",
  "author": "Gorkbot",
  "entry_point": "tool.py",
  "category": "memory",
  "requires": ["chromadb", "sentence-transformers"],
  "parameters": {
    "action": {
      "type": "string",
      "description": "store | search | stats | purge",
      "required": true
    },
    "content": {
      "type": "string",
      "description": "Text to embed and store",
      "required": false,
      "default": ""
    },
    "query": {
      "type": "string",
      "description": "Semantic search query",
      "required": false,
      "default": ""
    },
    "metadata": {
      "type": "string",
      "description": "JSON metadata tags for store",
      "required": false,
      "default": "{}"
    },
    "n_results": {
      "type": "integer",
      "description": "Results to return (search)",
      "required": false,
      "default": "5"
    },
    "min_score": {
      "type": "number",
      "description": "Min similarity score 0.0-1.0",
      "required": false,
      "default": "0.0"
    }
  }
}
