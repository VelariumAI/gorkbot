{
    "name": "scrapling_dynamic",
    "version": "1.0.0",
    "description": "Full browser automation for dynamic JavaScript-heavy websites",
    "author": "gorkbot",
    "entry_point": "tool.py",
    "parameters": {
        "url": {
            "type": "string",
            "description": "URL to fetch",
            "required": true
        },
        "selector": {
            "type": "string",
            "description": "CSS or XPath selector to extract elements",
            "required": false,
            "default": ""
        },
        "headless": {
            "type": "boolean",
            "description": "Run browser in headless mode",
            "required": false,
            "default": true
        },
        "network_idle": {
            "type": "boolean",
            "description": "Wait for network idle after page load",
            "required": false,
            "default": true
        },
        "wait_for": {
            "type": "string",
            "description": "CSS selector to wait for before extracting",
            "required": false,
            "default": ""
        },
        "get_text": {
            "type": "boolean",
            "description": "Extract text content only",
            "required": false,
            "default": false
        },
        "get_all": {
            "type": "boolean",
            "description": "Get all matches",
            "required": false,
            "default": true
        },
        "timeout": {
            "type": "number",
            "description": "Request timeout in seconds",
            "required": false,
            "default": 60
        }
    },
    "requires": ["scrapling[fetchers]"],
    "category": "web"
}
